<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="745.0" prefWidth="1215.0" spacing="10.0" style="-fx-padding: 25;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.krisapps.incomeutility_v2.IncomeUtilityController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <children>
      <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="KrisApps Income Utility v2.0">
         <font>
            <Font name="System Bold" size="22.0" />
         </font>
      </Label>
      <VBox styleClass="utility-view">
         <children>
            <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Available utilities">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
            </Label>
            <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Click on the utility to open it, or shift-click to bring the selected utility to the front">
               <padding>
                  <Insets bottom="5.0" />
               </padding>
               <font>
                  <Font size="14.0" />
               </font>
            </Label>
            <TilePane alignment="CENTER_LEFT" hgap="20.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" styleClass="utility-container" tileAlignment="CENTER_LEFT" vgap="40.0">
               <children>
                  <VBox fx:id="mimoCell" alignment="CENTER" styleClass="utility-cell">
                     <children>
                        <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../../../../../../../Pictures/profile_logo.jpg" />
                           </image>
                        </ImageView>
                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Money In Money Out">
                           <padding>
                              <Insets top="5.0" />
                           </padding>
                           <font>
                              <Font name="System Bold" size="16.0" />
                           </font>
                           <styleClass>
                              <String fx:value="medium-label" />
                              <String fx:value="bold" />
                           </styleClass>
                        </Label>
                     </children>
                  </VBox>
                  <VBox fx:id="pricerCell" alignment="CENTER" styleClass="utility-cell">
                     <children>
                        <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../../../../../../../Pictures/profile_logo.jpg" />
                           </image>
                        </ImageView>
                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Pricer">
                           <padding>
                              <Insets top="5.0" />
                           </padding>
                           <font>
                              <Font name="System Bold" size="16.0" />
                           </font>
                           <styleClass>
                              <String fx:value="medium-label" />
                              <String fx:value="bold" />
                           </styleClass>
                        </Label>
                     </children>
                  </VBox>
                  <VBox fx:id="subscriptionsCell" alignment="CENTER" styleClass="utility-cell">
                     <children>
                        <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../../../../../../../../Pictures/profile_logo.jpg" />
                           </image>
                        </ImageView>
                        <Label alignment="CENTER" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Subscriptions">
                           <padding>
                              <Insets top="5.0" />
                           </padding>
                           <font>
                              <Font name="System Bold" size="16.0" />
                           </font>
                           <styleClass>
                              <String fx:value="medium-label" />
                              <String fx:value="bold" />
                           </styleClass>
                        </Label>
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets top="5.0" />
               </padding>
            </TilePane>
         </children>
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
      </VBox>
   </children>
   <stylesheets>
      <URL value="@stylesheets/core-ui.css" />
      <URL value="@stylesheets/main.css" />
   </stylesheets>
</VBox>
