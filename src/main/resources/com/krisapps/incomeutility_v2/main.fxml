<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import java.lang.*?>
<?import java.net.URL?>
<VBox alignment="TOP_CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.krisapps.incomeutility_v2.IncomeUtilityController">
   <children>
      <VBox fx:id="root" alignment="TOP_CENTER" maxHeight="1.7976931348623157E308" maxWidth="1280.0" minHeight="-Infinity" minWidth="-Infinity" VBox.vgrow="ALWAYS">
         <children>
            <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="KrisApps Income Utility v2.0">
               <font>
                  <Font name="System Bold" size="22.0" />
               </font>
               <VBox.margin>
                  <Insets bottom="10.0" />
               </VBox.margin>
            </Label>
            <HBox maxHeight="150.0" maxWidth="1.7976931348623157E308" spacing="20.0" VBox.vgrow="SOMETIMES">
               <VBox.margin>
                  <Insets bottom="10.0" top="10.0"/>
               </VBox.margin>
               <children>
                  <VBox maxWidth="1.7976931348623157E308" styleClass="utility-view" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox maxWidth="1.7976931348623157E308">
                           <children>
                              <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity"
                                     text="Accounts" HBox.hgrow="ALWAYS">
                                 <font>
                                    <Font name="System Bold" size="22.0"/>
                                 </font>
                              </Label>
                              <Button mnemonicParsing="false" onAction="#promptCreateNewAccount" text="Add new account">
                                 <graphic>
                                    <FontIcon iconLiteral="fltfal-add-circle-20" iconSize="20"/>
                                 </graphic>
                              </Button>
                           </children>
                        </HBox>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity"
                               text="Click on the account to view more information">
                           <padding>
                              <Insets bottom="5.0"/>
                           </padding>
                           <font>
                              <Font size="14.0"/>
                           </font>
                        </Label>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxWidth="1.7976931348623157E308"
                                    VBox.vgrow="SOMETIMES">
                           <content>
                              <GridPane fx:id="accountView" hgap="10.0" maxHeight="1.7976931348623157E308"
                                        maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity"
                                        vgap="10.0">
                                 <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0"/>
                                 </columnConstraints>
                                 <rowConstraints>
                                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES"/>
                                 </rowConstraints>
                                 <padding>
                                    <Insets right="10.0"/>
                                 </padding>
                              </GridPane>
                           </content>
                        </ScrollPane>
                     </children>
                  </VBox>
                  <VBox maxWidth="1.7976931348623157E308" styleClass="utility-view" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox maxWidth="1.7976931348623157E308">
                           <children>
                              <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity"
                                     text="Quick Actions" HBox.hgrow="ALWAYS">
                                 <font>
                                    <Font name="System Bold" size="22.0"/>
                                 </font>
                              </Label>
                           </children>
                        </HBox>
                        <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity"
                               text="Access frequently used actions from the dashboard">
                           <padding>
                              <Insets bottom="5.0"/>
                           </padding>
                           <font>
                              <Font size="14.0"/>
                           </font>
                        </Label>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" maxWidth="1.7976931348623157E308"
                                    VBox.vgrow="SOMETIMES">
                           <content>
                              <VBox fillWidth="false" maxWidth="1.7976931348623157E308">
                                 <children>
                                    <VBox alignment="CENTER" minHeight="75.0" minWidth="75.0"
                                          onMouseClicked="#promptImportTransactions">
                                       <children>
                                          <FontIcon iconLiteral="fltral-arrow-download-24" iconSize="36"/>
                                          <Label alignment="CENTER" maxWidth="1.7976931348623157E308"
                                                 minHeight="-Infinity" minWidth="-Infinity"
                                                 text="Import transactions...">
                                             <padding>
                                                <Insets top="5.0"/>
                                             </padding>
                                             <font>
                                                <Font name="System Bold" size="16.0"/>
                                             </font>
                                             <styleClass>
                                                <String fx:value="normal-label"/>
                                                <String fx:value="bold"/>
                                             </styleClass>
                                          </Label>
                                       </children>
                                       <styleClass>
                                          <String fx:value="rounded-container"/>
                                          <String fx:value="large"/>
                                       </styleClass>
                                    </VBox>
                                 </children>
                              </VBox>
                           </content>
                        </ScrollPane>
                     </children>
                  </VBox>
               </children>
            </HBox>
            <VBox maxWidth="1.7976931348623157E308" styleClass="utility-view" VBox.vgrow="SOMETIMES">
               <children>
                  <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Available utilities">
                     <font>
                        <Font name="System Bold" size="22.0" />
                     </font>
                  </Label>
                  <Label maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Click on the utility to open it, or shift-click to bring the selected utility to the front">
                     <padding>
                        <Insets bottom="5.0" />
                     </padding>
                     <font>
                        <Font size="14.0" />
                     </font>
                  </Label>
                  <TilePane fx:id="utilitiesView" alignment="CENTER_LEFT" hgap="20.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" styleClass="utility-container" tileAlignment="CENTER_LEFT" vgap="40.0">
                     <children>
                        <VBox fx:id="mimoCell" alignment="CENTER" styleClass="utility-cell">
                           <children>
                              <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@icons/money_in_money_out_96.png" />
                                 </image>
                              </ImageView>
                              <Label alignment="CENTER" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Money In Money Out">
                                 <padding>
                                    <Insets top="5.0" />
                                 </padding>
                                 <font>
                                    <Font name="System Bold" size="16.0" />
                                 </font>
                                 <styleClass>
                                    <String fx:value="medium-label" />
                                    <String fx:value="bold" />
                                 </styleClass>
                              </Label>
                           </children>
                        </VBox>
                        <VBox fx:id="breakdownCell" alignment="CENTER" styleClass="utility-cell">
                           <children>
                              <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@icons/fiscal_breakdown_96.png" />
                                 </image>
                              </ImageView>
                              <Label alignment="CENTER" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Fiscal Breakdown">
                                 <padding>
                                    <Insets top="5.0" />
                                 </padding>
                                 <font>
                                    <Font name="System Bold" size="16.0" />
                                 </font>
                                 <styleClass>
                                    <String fx:value="medium-label" />
                                    <String fx:value="bold" />
                                 </styleClass>
                              </Label>
                           </children>
                        </VBox>
                        <VBox fx:id="pricerCell" alignment="CENTER" styleClass="utility-cell">
                           <children>
                              <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@icons/pricer_96.png" />
                                 </image>
                              </ImageView>
                              <Label alignment="CENTER" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Pricer">
                                 <padding>
                                    <Insets top="5.0" />
                                 </padding>
                                 <font>
                                    <Font name="System Bold" size="16.0" />
                                 </font>
                                 <styleClass>
                                    <String fx:value="medium-label" />
                                    <String fx:value="bold" />
                                 </styleClass>
                              </Label>
                           </children>
                        </VBox>
                        <VBox fx:id="subscriptionsCell" alignment="CENTER" disable="true" styleClass="utility-cell">
                           <children>
                              <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@icons/subscriptions_96.png" />
                                 </image>
                              </ImageView>
                              <Label alignment="CENTER" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Subscriptions">
                                 <padding>
                                    <Insets top="5.0" />
                                 </padding>
                                 <font>
                                    <Font name="System Bold" size="16.0" />
                                 </font>
                                 <styleClass>
                                    <String fx:value="medium-label" />
                                    <String fx:value="bold"/>
                                 </styleClass>
                              </Label>
                           </children>
                        </VBox>
                        <VBox fx:id="settingsCell" alignment="CENTER" styleClass="utility-cell">
                           <children>
                              <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                                 <image>
                                    <Image url="@icons/settings_96.png"/>
                                 </image>
                              </ImageView>
                              <Label alignment="CENTER" maxWidth="1.7976931348623157E308" minHeight="-Infinity"
                                     minWidth="-Infinity" text="Settings">
                                 <padding>
                                    <Insets top="5.0"/>
                                 </padding>
                                 <font>
                                    <Font name="System Bold" size="16.0"/>
                                 </font>
                                 <styleClass>
                                    <String fx:value="medium-label"/>
                                    <String fx:value="bold" />
                                 </styleClass>
                              </Label>
                           </children>
                        </VBox>
                     </children>
                     <padding>
                        <Insets top="5.0" />
                     </padding>
                  </TilePane>
               </children>
               <VBox.margin>
                  <Insets bottom="10.0" top="10.0" />
               </VBox.margin>
            </VBox>
         </children>
         <stylesheets>
            <URL value="@stylesheets/core-ui.css" />
            <URL value="@stylesheets/main.css" />
         </stylesheets>
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </VBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
