<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import org.kordamp.ikonli.javafx.*?>
<?import java.lang.*?>
<?import java.net.URL?>
<StackPane alignment="TOP_CENTER" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" spacing="10.0">
         <children>
            <VBox alignment="CENTER" maxWidth="1280.0" minHeight="-Infinity" minWidth="-Infinity" VBox.vgrow="ALWAYS">
               <children>
                  <HBox maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" spacing="10.0">
                     <children>
                        <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" spacing="20.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="title" text="Money In, Money Out">
                                 <font>
                                    <Font name="System Bold" size="22.0" />
                                 </font>
                              </Label>
                              <Button fx:id="backButton" maxHeight="1.7976931348623157E308" mnemonicParsing="false" text="Back">
                                 <graphic>
                                    <FontIcon iconLiteral="fltfal-arrow-hook-up-left-20" iconSize="12" />
                                 </graphic>
                              </Button>
                           </children>
                        </HBox>
                        <ComboBox fx:id="accountSelector" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="250.0" HBox.hgrow="SOMETIMES" />
                     </children>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </HBox>
                  <Separator maxHeight="50.0" minHeight="25.0" orientation="VERTICAL" visible="false" VBox.vgrow="ALWAYS">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </Separator>
                  <HBox alignment="CENTER" maxHeight="80.0" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="60.0" spacing="10.0" styleClass="rounded-container" VBox.vgrow="ALWAYS">
                     <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </padding>
                     <children>
                        <VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" spacing="2.5" styleClass="leftmost-container" HBox.hgrow="ALWAYS">
                           <children>
                              <Label alignment="CENTER" styleClass="normal-label" text="Balance">
                                 <font>
                                    <Font size="16.0" />
                                 </font>
                              </Label>
                              <Label fx:id="currentBalanceLabel" alignment="CENTER" text="0.00">
                                 <font>
                                    <Font name="System Bold" size="20.0" />
                                 </font>
                                 <graphic>
                                    <FontIcon iconLiteral="fltfal-building-bank-20" iconSize="15" styleClass="font-icon" />
                                 </graphic>
                                 <styleClass>
                                    <String fx:value="xl-label" />
                                    <String fx:value="bold" />
                                 </styleClass>
                              </Label>
                           </children>
                           <padding>
                              <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                           </padding>
                           <HBox.margin>
                              <Insets />
                           </HBox.margin>
                        </VBox>
                        <VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" spacing="2.5" styleClass="hoverable-container" HBox.hgrow="ALWAYS">
                           <children>
                              <Label alignment="CENTER" styleClass="normal-label" text="Starting balance">
                                 <font>
                                    <Font size="16.0" />
                                 </font>
                              </Label>
                              <Label fx:id="startingBalanceLabel" alignment="CENTER" styleClass="xl-label" text="0.00">
                                 <font>
                                    <Font name="System Bold" size="20.0" />
                                 </font>
                                 <graphic>
                                    <FontIcon iconLiteral="fltfal-calendar-20" iconSize="15" styleClass="font-icon" />
                                 </graphic>
                              </Label>
                           </children>
                           <padding>
                              <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                           </padding>
                        </VBox>
                        <VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" spacing="2.5" styleClass="hoverable-container" HBox.hgrow="ALWAYS">
                           <children>
                              <Label alignment="CENTER" styleClass="normal-label" text="Inflow">
                                 <font>
                                    <Font size="16.0" />
                                 </font>
                              </Label>
                              <Label fx:id="inflowLabel" alignment="CENTER" text="0.00">
                                 <font>
                                    <Font name="System Bold" size="20.0" />
                                 </font>
                                 <styleClass>
                                    <String fx:value="green-positive" />
                                    <String fx:value="xl-label" />
                                 </styleClass>
                                 <graphic>
                                    <FontIcon iconLiteral="fltfal-arrow-up-20" iconSize="15">
                                       <styleClass>
                                          <String fx:value="green-positive" />
                                          <String fx:value="font-icon" />
                                       </styleClass>
                                    </FontIcon>
                                 </graphic>
                              </Label>
                           </children>
                           <padding>
                              <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                           </padding>
                        </VBox>
                        <VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" spacing="2.5" styleClass="hoverable-container" HBox.hgrow="ALWAYS">
                           <children>
                              <Label alignment="CENTER" styleClass="normal-label" text="Outflow">
                                 <font>
                                    <Font size="16.0" />
                                 </font>
                              </Label>
                              <Label fx:id="outflowLabel" alignment="CENTER" text="0.00">
                                 <font>
                                    <Font name="System Bold" size="20.0" />
                                 </font>
                                 <styleClass>
                                    <String fx:value="red-negative" />
                                    <String fx:value="xl-label" />
                                 </styleClass>
                                 <graphic>
                                    <FontIcon iconLiteral="fltfal-arrow-down-20" iconSize="15">
                                       <styleClass>
                                          <String fx:value="red-negative" />
                                          <String fx:value="font-icon" />
                                       </styleClass>
                                    </FontIcon>
                                 </graphic>
                              </Label>
                           </children>
                           <padding>
                              <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                           </padding>
                        </VBox>
                        <VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" spacing="2.5" HBox.hgrow="ALWAYS">
                           <children>
                              <Label alignment="CENTER" styleClass="normal-label" text="Change">
                                 <font>
                                    <Font size="16.0" />
                                 </font>
                              </Label>
                              <Label fx:id="changeLabel" alignment="CENTER" styleClass="xl-label" text="0.00">
                                 <font>
                                    <Font name="System Bold" size="20.0" />
                                 </font>
                                 <graphic>
                                    <FontIcon iconLiteral="fltfal-arrow-sort-20" iconSize="15" styleClass="font-icon" />
                                 </graphic>
                              </Label>
                           </children>
                           <padding>
                              <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                           </padding>
                           <styleClass>
                              <String fx:value="hoverable-container" />
                              <String fx:value="rightmost-container" />
                           </styleClass>
                        </VBox>
                     </children>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </HBox>
                  <Separator maxHeight="75.0" minHeight="25.0" orientation="VERTICAL" visible="false" VBox.vgrow="ALWAYS" />
                  <Label fx:id="dateTitle" maxWidth="1.7976931348623157E308" text="Tuesday, June 9th">
                     <VBox.margin>
                         <Insets bottom="5.0"/>
                     </VBox.margin>
                     <styleClass>
                         <String fx:value="large-label"/>
                         <String fx:value="bold"/>
                     </styleClass>
                  </Label>
                  <VBox maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
                     <children>
                        <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" spacing="5.0">
                           <children>
                              <DatePicker fx:id="datePicker" maxHeight="1.7976931348623157E308" maxWidth="250.0" prefWidth="250.0" />
                               <Button fx:id="prevDayButton" maxHeight="1.7976931348623157E308" mnemonicParsing="false">
                                 <graphic>
                                    <FontIcon iconLiteral="fltfal-arrow-left-24" iconSize="16" />
                                 </graphic>
                              </Button>
                               <Button fx:id="nextDayButton" maxHeight="1.7976931348623157E308" mnemonicParsing="false">
                                 <graphic>
                                    <FontIcon iconLiteral="fltfal-arrow-right-24" iconSize="16" />
                                 </graphic>
                              </Button>
                               <Button fx:id="resetDateButton" maxHeight="1.7976931348623157E308"
                                       mnemonicParsing="false">
                                 <graphic>
                                    <FontIcon iconLiteral="fltfal-calendar-24" iconSize="16" />
                                 </graphic>
                               </Button>
                               <Button fx:id="searchButton" maxHeight="1.7976931348623157E308" mnemonicParsing="false">
                                   <graphic>
                                       <FontIcon iconLiteral="fltfmz-search-24" iconSize="15"/>
                                 </graphic>
                              </Button>
                              <Separator prefWidth="200.0" visible="false" HBox.hgrow="ALWAYS" />
                              <MenuButton fx:id="addTransactionButton" maxHeight="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" text="New transaction" HBox.hgrow="ALWAYS">
                                <items>
                                  <MenuItem mnemonicParsing="false" onAction="#promptAddSingleTransaction" text="Add single" />
                                  <MenuItem mnemonicParsing="false" onAction="#promptAddMultipleTransactions" text="Add multiple" />
                                    <MenuItem mnemonicParsing="false" onAction="#promptImportTransactions" text="Import transactions..." />
                                </items>
                                 <graphic>
                                    <FontIcon iconLiteral="fltfal-add-circle-24" iconSize="14" wrappingWidth="15.0" />
                                 </graphic>
                              </MenuButton>
                           </children>
                           <VBox.margin>
                              <Insets bottom="5.0" />
                           </VBox.margin>
                        </HBox>
                        <ListView fx:id="transactionList" prefHeight="200.0" prefWidth="200.0" styleClass="transaction-list" VBox.vgrow="ALWAYS" />
                        <Label alignment="CENTER_RIGHT" maxWidth="1.7976931348623157E308" styleClass="medium-label" text="Click on the transaction to view more options">
                           <padding>
                              <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                           </padding>
                        </Label>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
      <HBox fx:id="commandPrompt" alignment="CENTER_LEFT" fillHeight="false" maxHeight="30.0" maxWidth="1280.0" styleClass="command-prompt" stylesheets="@../../stylesheets/utilities.css">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <StackPane.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </StackPane.margin>
         <children>
            <Label fx:id="commandPromptLabel" styleClass="prompt-label" text="money-flow">
               <HBox.margin>
                  <Insets right="5.0" />
               </HBox.margin>
            </Label>
            <TextField fx:id="commandPromptField" maxWidth="1.7976931348623157E308" styleClass="prompt" HBox.hgrow="ALWAYS" />
         </children>
      </HBox>
   </children>
   <stylesheets>
      <URL value="@../../stylesheets/core-ui.css" />
      <URL value="@../../stylesheets/main.css" />
      <URL value="@../../stylesheets/utilities.css" />
   </stylesheets>
</StackPane>
