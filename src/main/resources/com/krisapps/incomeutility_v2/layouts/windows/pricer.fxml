                                                               <styleClass>
                                                                   <String fx:value="large-label"/>
                                                                   <String fx:value="flair-generic"/>
                                                               </styleClass>
                                                           </Label>
                                                           <Label fx:id="individualPPUTotal" alignment="CENTER"
                                                                  maxHeight="1.7976931348623157E308"
                                                                  maxWidth="1.7976931348623157E308" text="0.00€"
                                                                  VBox.vgrow="ALWAYS">
                                                               <styleClass>
                                                                   <String fx:value="xl-label"/>
                                                                   <String fx:value="bold"/>
                                                               </styleClass>
                                                           </Label>
                                                       </children>
                                                   </VBox>
                                               </children>
