                                   <VBox spacing="20.0">
                                       <children>
                                           <HBox prefHeight="100.0" prefWidth="200.0" spacing="20.0">
                                               <children>
                                                   <VBox maxHeight="1.7976931348623157E308"
                                                         maxWidth="1.7976931348623157E308" spacing="5.0"
                                                         HBox.hgrow="ALWAYS">
                                                       <children>
                                                           <Label text="Product name">
                                                               <styleClass>
                                                                   <String fx:value="large-label"/>
                                                                   <String fx:value="bold"/>
                                                               </styleClass>
                                                           </Label>
                                                           <TextField fx:id="nameBox" maxHeight="1.7976931348623157E308"
                                                                      styleClass="large-label" VBox.vgrow="ALWAYS"/>
