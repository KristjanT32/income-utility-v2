                                                               <styleClass>
                                                                   <String fx:value="large-label"/>
                                                                   <String fx:value="bold"/>
                                                               </styleClass>
                                                           </Label>
                                                           <TextField fx:id="priceBox"
                                                                      maxHeight="1.7976931348623157E308"
                                                                      styleClass="large-label" VBox.vgrow="ALWAYS"/>
