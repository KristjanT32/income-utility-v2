<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<StackPane alignment="TOP_CENTER" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="662.0" prefWidth="871.0" spacing="10.0">
         <children>
            <VBox alignment="TOP_CENTER" maxWidth="1280.0" minHeight="-Infinity" minWidth="-Infinity" VBox.vgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" spacing="20.0">
                     <children>
                        <Label maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="title" text="Pricer">
                           <font>
                              <Font name="System Bold" size="22.0" />
                           </font>
                        </Label>
                        <Button fx:id="backButton" maxHeight="1.7976931348623157E308" mnemonicParsing="false" text="Back">
                           <graphic>
                              <FontIcon iconLiteral="fltfal-arrow-hook-up-left-20" iconSize="12" />
                           </graphic>
                        </Button>
                     </children>
                  </HBox>
                  <HBox prefHeight="100.0" prefWidth="200.0" spacing="20.0">
                     <children>
                        <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Product name">
                                 <styleClass>
                                    <String fx:value="large-label" />
                                    <String fx:value="bold" />
                                 </styleClass>
                              </Label>
                              <TextField fx:id="nameBox" maxHeight="1.7976931348623157E308" styleClass="large-label" VBox.vgrow="ALWAYS" />
                           </children>
                           <padding>
                              <Insets bottom="10.0" top="10.0" />
                           </padding>
                        </VBox>
                        <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Product price">
                                 <styleClass>
                                    <String fx:value="large-label" />
                                    <String fx:value="bold" />
                                 </styleClass>
                              </Label>
                              <TextField fx:id="priceBox" maxHeight="1.7976931348623157E308" styleClass="large-label" VBox.vgrow="ALWAYS" />
                           </children>
                           <padding>
                              <Insets bottom="10.0" top="10.0" />
                           </padding>
                        </VBox>
                        <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label text="Amount">
                                 <styleClass>
                                    <String fx:value="large-label" />
                                    <String fx:value="bold" />
                                 </styleClass>
                              </Label>
                              <TextField fx:id="amountBox" maxHeight="1.7976931348623157E308" styleClass="large-label" VBox.vgrow="ALWAYS" />
                           </children>
                           <padding>
                              <Insets bottom="10.0" top="10.0" />
                           </padding>
                        </VBox>
                        <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="5.0">
                           <children>
                              <Label text="Unit name">
                                 <styleClass>
                                    <String fx:value="large-label" />
                                    <String fx:value="bold" />
                                 </styleClass>
                              </Label>
                              <TextField fx:id="unitBox" maxHeight="1.7976931348623157E308" styleClass="large-label" VBox.vgrow="ALWAYS" />
                           </children>
                           <padding>
                              <Insets bottom="10.0" top="10.0" />
                           </padding>
                        </VBox>
                     </children>
                     <VBox.margin>
                        <Insets top="20.0" />
                     </VBox.margin>
                  </HBox>
                  <HBox spacing="5.0">
                     <VBox.margin>
                        <Insets bottom="20.0" />
                     </VBox.margin>
                     <children>
                        <Label maxHeight="1.7976931348623157E308" text="Average duration of product (days):" HBox.hgrow="ALWAYS">
                           <styleClass>
                              <String fx:value="large-label" />
                              <String fx:value="bold" />
                           </styleClass>
                        </Label>
                        <Spinner fx:id="durationSpinner" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="large-label" HBox.hgrow="ALWAYS" />
                     </children>
                  </HBox>
                  <HBox prefHeight="100.0" prefWidth="200.0" spacing="20.0">
                     <children>
                        <VBox maxHeight="1.7976931348623157E308" styleClass="rounded-container" HBox.hgrow="ALWAYS">
                           <children>
                              <Label alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="Price per unit" VBox.vgrow="ALWAYS">
                                 <styleClass>
                                    <String fx:value="large-label" />
                                    <String fx:value="flair-generic" />
                                 </styleClass>
                              </Label>
                              <Label fx:id="ppuLabel" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="0.00€" VBox.vgrow="ALWAYS">
                                 <styleClass>
                                    <String fx:value="xl-label" />
                                    <String fx:value="bold" />
                                 </styleClass>
                              </Label>
                           </children>
                        </VBox>
                        <VBox maxHeight="1.7976931348623157E308" styleClass="rounded-container" HBox.hgrow="ALWAYS">
                           <children>
                              <Label alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="Price per unit of time" VBox.vgrow="ALWAYS">
                                 <styleClass>
                                    <String fx:value="large-label" />
                                    <String fx:value="flair-generic" />
                                 </styleClass>
                              </Label>
                              <Label fx:id="pputLabel" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="0.00€" VBox.vgrow="ALWAYS">
                                 <styleClass>
                                    <String fx:value="xl-label" />
                                    <String fx:value="bold" />
                                 </styleClass>
                              </Label>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
      <HBox fx:id="commandPrompt" alignment="CENTER_LEFT" fillHeight="false" maxHeight="30.0" maxWidth="1280.0" styleClass="command-prompt" stylesheets="@../../stylesheets/utilities.css" visible="false">
         <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </padding>
         <StackPane.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </StackPane.margin>
         <children>
            <Label fx:id="commandPromptLabel" styleClass="prompt-label" text="pricer">
               <HBox.margin>
                  <Insets right="5.0" />
               </HBox.margin>
            </Label>
            <TextField fx:id="commandPromptField" maxWidth="1.7976931348623157E308" styleClass="prompt" HBox.hgrow="ALWAYS" />
         </children>
      </HBox>
   </children>
   <stylesheets>
      <URL value="@../../stylesheets/core-ui.css" />
      <URL value="@../../stylesheets/main.css" />
      <URL value="@../../stylesheets/utilities.css" />
   </stylesheets>
</StackPane>
