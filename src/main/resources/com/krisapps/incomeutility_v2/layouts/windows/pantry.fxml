<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import java.net.URL?>
<StackPane alignment="TOP_CENTER" prefHeight="660.0" prefWidth="1150.0" xmlns="http://javafx.com/javafx/25"
           xmlns:fx="http://javafx.com/fxml/1">
    <stylesheets>
        <URL value="@../../stylesheets/core-ui.css"/>
        <URL value="@../../stylesheets/main.css"/>
        <URL value="@../../stylesheets/utilities.css"/>
    </stylesheets>
    <VBox alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
          minHeight="-Infinity" minWidth="-Infinity" spacing="10.0">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
        </padding>
        <VBox alignment="TOP_CENTER" maxWidth="1280.0" minHeight="-Infinity" minWidth="-Infinity"
              VBox.vgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" spacing="20.0">
                <Label maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                       styleClass="title" text="Pantry">
                    <font>
                        <Font name="System Bold" size="22.0"/>
                    </font>
                </Label>
                <Button fx:id="backButton" maxHeight="1.7976931348623157E308" mnemonicParsing="false"
                        text="Back">
                    <graphic>
                        <FontIcon iconLiteral="fltfal-arrow-hook-up-left-20" iconSize="12"/>
                    </graphic>
                </Button>
            </HBox>
        </VBox>
    </VBox>
    <HBox fx:id="commandPrompt" alignment="CENTER_LEFT" fillHeight="false" maxHeight="30.0" maxWidth="1280.0"
          styleClass="command-prompt" stylesheets="@../../stylesheets/utilities.css" visible="false">
        <padding>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
        </padding>
        <StackPane.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
        </StackPane.margin>
        <children>
            <Label fx:id="commandPromptLabel" styleClass="prompt-label" text="pantry">
                <HBox.margin>
                    <Insets right="5.0"/>
                </HBox.margin>
            </Label>
            <TextField fx:id="commandPromptField" maxWidth="1.7976931348623157E308" styleClass="prompt"
                       HBox.hgrow="ALWAYS"/>
        </children>
    </HBox>
</StackPane>
