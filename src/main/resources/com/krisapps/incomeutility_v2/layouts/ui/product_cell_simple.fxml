<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import java.lang.*?>
<?import java.net.URL?>
<VBox fx:id="rootPane" alignment="CENTER_LEFT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
      styleClass="product-cell" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox alignment="CENTER_LEFT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
              VBox.vgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT" spacing="5.0" translateY="2.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="productNameLabel" maxHeight="1.7976931348623157E308"
                               maxWidth="1.7976931348623157E308" text="A long product name, taking a lot of space"
                               wrapText="true" HBox.hgrow="ALWAYS">
                            <font>
                                <Font name="Segoe UI Bold" size="14.0"/>
                            </font>
                            <styleClass>
                                <String fx:value="large-label"/>
                                <String fx:value="bold"/>
                            </styleClass>
                        </Label>
                    </children>
                    <HBox.margin>
                        <Insets right="10.0"/>
                    </HBox.margin>
                </HBox>
                <HBox alignment="CENTER_RIGHT" maxWidth="1.7976931348623157E308" minWidth="200.0" spacing="5.0"
                      HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_RIGHT" maxHeight="1.7976931348623157E308"
                              maxWidth="1.7976931348623157E308" spacing="10.0" HBox.hgrow="ALWAYS">
                            <HBox.margin>
                                <Insets right="10.0"/>
                            </HBox.margin>
                            <children>
                                <Label fx:id="priceLabel" alignment="CENTER_RIGHT" maxHeight="1.7976931348623157E308"
                                       maxWidth="1.7976931348623157E308" minWidth="50.0" text="\$0.00"
                                       HBox.hgrow="ALWAYS">
                                    <styleClass>
                                        <String fx:value="xl-label"/>
                                        <String fx:value="bold"/>
                                    </styleClass>
                        </Label>
                                <Label fx:id="quantityLabel" alignment="CENTER" maxHeight="1.7976931348623157E308"
                                       maxWidth="100.0" minWidth="50.0" text="200g" HBox.hgrow="ALWAYS">
                                    <styleClass>
                                        <String fx:value="rounded-container"/>
                                        <String fx:value="large"/>
                                        <String fx:value="bold"/>
                                    </styleClass>
                        </Label>
                            </children>
                        </HBox>
                        <HBox fx:id="buttonBar" spacing="5.0">
                            <children>
                                <Button fx:id="addButton" maxHeight="1.7976931348623157E308" mnemonicParsing="false"
                                        styleClass="positive">
                                    <graphic>
                                        <FontIcon iconLiteral="fltral-add-circle-24" iconSize="16"/>
                                    </graphic>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>
    <stylesheets>
        <URL value="@../../stylesheets/core-ui.css"/>
        <URL value="@../../stylesheets/main.css"/>
    </stylesheets>
</VBox>
