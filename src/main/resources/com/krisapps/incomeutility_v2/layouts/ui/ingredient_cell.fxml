<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import java.lang.String?>
<?import java.net.URL?>
<VBox fx:id="rootPane" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="product-cell"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox alignment="CENTER_LEFT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
              VBox.vgrow="SOMETIMES">
            <children>
                <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefWidth="200.0"
                      HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="productNameLabel" maxHeight="1.7976931348623157E308"
                               maxWidth="1.7976931348623157E308" text="Product Name">
                            <font>
                                <Font name="Segoe UI Bold" size="14.0"/>
                            </font>
                            <styleClass>
                                <String fx:value="large-label"/>
                                <String fx:value="bold"/>
                            </styleClass>
                        </Label>
                        <Label fx:id="priceLabel" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                               styleClass="large-label" text="\$20.00">
                            <font>
                                <Font name="Segoe UI Bold" size="14.0"/>
                            </font>
                        </Label>
                    </children>
                </VBox>
                <Separator maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" visible="false"
                           HBox.hgrow="ALWAYS"/>
                <HBox fx:id="quantityControls" spacing="5.0">
                    <children>
                        <Button fx:id="increaseQuantity" maxHeight="1.7976931348623157E308" minHeight="35.0"
                                minWidth="35.0" mnemonicParsing="false" styleClass="positive">
                            <graphic>
                                <FontIcon iconLiteral="fltfal-add-24" iconSize="16"/>
                            </graphic>
                        </Button>
                        <TextField fx:id="quantityBox" alignment="CENTER" maxHeight="1.7976931348623157E308"
                                   maxWidth="75.0" styleClass="medium" text="0" HBox.hgrow="SOMETIMES"/>
                        <Button fx:id="decreaseQuantity" maxHeight="1.7976931348623157E308" minHeight="35.0"
                                minWidth="35.0" mnemonicParsing="false" styleClass="destructive">
                            <graphic>
                                <FontIcon iconLiteral="fltfmz-minimize-24" iconSize="16"/>
                            </graphic>
                        </Button>
                    </children>
                </HBox>
                <Button fx:id="deleteButton" maxHeight="1.7976931348623157E308" minHeight="35.0" minWidth="35.0"
                        mnemonicParsing="false" styleClass="destructive">
                    <graphic>
                        <FontIcon iconLiteral="fltfal-delete-24" iconSize="16"/>
                    </graphic>
                    <HBox.margin>
                        <Insets left="10.0"/>
                    </HBox.margin>
                </Button>
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>
    <stylesheets>
        <URL value="@../../stylesheets/core-ui.css"/>
        <URL value="@../../stylesheets/main.css"/>
    </stylesheets>
</VBox>
