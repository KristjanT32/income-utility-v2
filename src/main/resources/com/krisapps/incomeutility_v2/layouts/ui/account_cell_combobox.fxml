<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<HBox fx:id="rootPane" alignment="CENTER_LEFT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" spacing="5.0" stylesheets="@../../stylesheets/core-ui.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <children>
      <Label fx:id="nameLabel" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" text="Account name" HBox.hgrow="ALWAYS">
         <styleClass>
            <String fx:value="medium-label" />
            <String fx:value="bold" />
         </styleClass>
      </Label>
      <Label fx:id="balanceLabel" alignment="CENTER_RIGHT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" styleClass="normal-label" text="500.00€" textAlignment="CENTER" textFill="#009005" HBox.hgrow="SOMETIMES">
         <HBox.margin>
            <Insets left="10.0" right="10.0" />
         </HBox.margin>
         <graphic>
            <FontIcon iconColor="#009005" iconLiteral="fltfmz-money-20" iconSize="14" textAlignment="CENTER" wrappingWidth="20.0" />
         </graphic>
      </Label>
   </children>
</HBox>
