<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import java.lang.*?>
<?import java.net.URL?>
<VBox fx:id="rootPane" alignment="CENTER_LEFT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
      styleClass="product-cell" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <children>
        <HBox alignment="CENTER_LEFT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
              VBox.vgrow="ALWAYS">
            <children>
                <HBox alignment="CENTER_LEFT" maxWidth="1.7976931348623157E308" spacing="5.0" HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="dishNameLabel" maxHeight="1.7976931348623157E308"
                               maxWidth="1.7976931348623157E308" text="A long dish name, taking a lot of space"
                               wrapText="true" HBox.hgrow="ALWAYS">
                            <font>
                                <Font name="Segoe UI Bold" size="14.0"/>
                            </font>
                            <styleClass>
                                <String fx:value="large-label"/>
                                <String fx:value="bold"/>
                            </styleClass>
                        </Label>
                    </children>
                    <HBox.margin>
                        <Insets right="10.0"/>
                    </HBox.margin>
                </HBox>
                <HBox alignment="CENTER_RIGHT" maxWidth="500.0" spacing="5.0" HBox.hgrow="ALWAYS">
                    <children>
                        <HBox alignment="CENTER_RIGHT" maxHeight="1.7976931348623157E308"
                              maxWidth="1.7976931348623157E308" prefWidth="250.0" spacing="10.0" HBox.hgrow="ALWAYS">
                            <HBox.margin>
                                <Insets right="10.0"/>
                            </HBox.margin>
                            <children>
                                <Label fx:id="servingPriceLabel" alignment="CENTER" maxHeight="1.7976931348623157E308"
                                       maxWidth="250.0" minWidth="200.0" text="1.30€ per serving" HBox.hgrow="ALWAYS">
                                    <styleClass>
                                        <String fx:value="rounded-container"/>
                                        <String fx:value="large"/>
                                        <String fx:value="bold"/>
                                    </styleClass>
                                </Label>
                                <Label fx:id="servingCountLabel" alignment="CENTER" maxHeight="1.7976931348623157E308"
                                       maxWidth="150.0" minWidth="100.0" text="6 servings" HBox.hgrow="ALWAYS">
                                    <styleClass>
                                        <String fx:value="rounded-container"/>
                                        <String fx:value="large"/>
                                        <String fx:value="bold"/>
                                    </styleClass>
                                </Label>
                            </children>
                        </HBox>
                        <HBox fx:id="buttonBar" spacing="5.0">
                            <children>
                                <Button fx:id="openButton" maxHeight="1.7976931348623157E308" minWidth="100.0"
                                        mnemonicParsing="false" styleClass="positive" text="View">
                                    <graphic>
                                        <FontIcon iconLiteral="fltrmz-open-24" iconSize="15"/>
                                    </graphic>
                                </Button>
                                <Button fx:id="editButton" maxHeight="1.7976931348623157E308" minWidth="30.0"
                                        mnemonicParsing="false" styleClass="account-cell">
                                    <graphic>
                                        <FontIcon iconLiteral="fltral-edit-24" iconSize="16"/>
                                    </graphic>
                                </Button>
                                <Button fx:id="deleteButton" maxHeight="1.7976931348623157E308" minWidth="30.0"
                                        mnemonicParsing="false" styleClass="destructive">
                                    <graphic>
                                        <FontIcon iconLiteral="fltral-delete-24" iconSize="16"/>
                                    </graphic>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </HBox>
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
    </padding>
    <stylesheets>
        <URL value="@../../stylesheets/core-ui.css"/>
        <URL value="@../../stylesheets/main.css"/>
    </stylesheets>
</VBox>
