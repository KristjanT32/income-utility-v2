<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import java.lang.String?>
<?import java.net.URL?>
<VBox maxHeight="1.7976931348623157E308" maxWidth="500.0" minHeight="150.0" minWidth="400.0" spacing="10.0"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    <children>
        <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" VBox.vgrow="ALWAYS">
            <children>
                <Label fx:id="primaryLabel" alignment="TOP_LEFT" maxHeight="1.7976931348623157E308"
                       maxWidth="1.7976931348623157E308" styleClass="title" text="Generate shopping list"/>
                <Label fx:id="descriptionLabel" alignment="TOP_LEFT" maxHeight="1.7976931348623157E308"
                       maxWidth="1.7976931348623157E308" styleClass="medium-label"
                       text="Setup your shopping list before generation" wrapText="true" VBox.vgrow="SOMETIMES">
                    <VBox.margin>
                        <Insets top="5.0"/>
                    </VBox.margin>
                </Label>
                <Separator maxWidth="1.7976931348623157E308" minHeight="15.0" orientation="VERTICAL" visible="false"
                           VBox.vgrow="ALWAYS"/>
                <VBox spacing="20.0">
                    <children>
                        <VBox>
                            <children>
                                <Label fx:id="descriptionLabel1" alignment="TOP_LEFT" maxHeight="1.7976931348623157E308"
                                       maxWidth="1.7976931348623157E308"
                                       text="Name of the store you wish to visit (optional)" wrapText="true">
                                    <styleClass>
                                        <String fx:value="normal-label"/>
                                        <String fx:value="bold"/>
                                    </styleClass>
                                    <VBox.margin>
                                        <Insets bottom="5.0"/>
                                    </VBox.margin>
                                </Label>
                                <TextField fx:id="storeNameField"
                                           promptText="Optional store name, or store names separated by commas"/>
                            </children>
                        </VBox>
                    </children>
                </VBox>
            </children>
            <VBox.margin>
                <Insets/>
            </VBox.margin>
        </VBox>
    </children>
    <stylesheets>
        <URL value="@../../stylesheets/core-ui.css"/>
        <URL value="@../../stylesheets/main.css"/>
    </stylesheets>
</VBox>
