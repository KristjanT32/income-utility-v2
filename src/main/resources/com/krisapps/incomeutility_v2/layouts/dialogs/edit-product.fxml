<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import java.net.URL?>
<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity"
      prefWidth="400.0" spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    <children>
        <Label styleClass="title" text="Edit product details">
            <VBox.margin>
                <Insets/>
            </VBox.margin>
        </Label>
        <VBox spacing="5.0">
            <children>
                <Label styleClass="header" text="Product name"/>
                <TextField fx:id="nameField" minHeight="35.0" promptText="Name..." styleClass="large">
                    <font>
                        <Font size="16.0"/>
                    </font>
                </TextField>
            </children>
            <padding>
                <Insets bottom="10.0" top="10.0"/>
            </padding>
        </VBox>
        <VBox spacing="5.0">
            <children>
                <Label styleClass="header" text="Price"/>
                <TextField fx:id="priceField" minHeight="35.0" promptText="0.00" styleClass="large">
                    <font>
                        <Font size="16.0"/>
                    </font>
                </TextField>
            </children>
            <padding>
                <Insets bottom="10.0" top="10.0"/>
            </padding>
        </VBox>
        <VBox spacing="5.0">
            <children>
                <Label styleClass="header" text="Quantity per package"/>
                <TextField fx:id="quantityField" minHeight="35.0" promptText="0.00" styleClass="large">
                    <font>
                        <Font size="16.0"/>
                    </font>
                </TextField>
            </children>
            <padding>
                <Insets bottom="10.0" top="10.0"/>
            </padding>
        </VBox>
        <VBox spacing="5.0">
            <children>
                <Label styleClass="header" text="Singular unit name"/>
                <TextField fx:id="singularUnitField" minHeight="35.0" promptText="gram" styleClass="large">
                    <font>
                        <Font size="16.0"/>
                    </font>
                </TextField>
            </children>
            <padding>
                <Insets bottom="10.0" top="10.0"/>
            </padding>
        </VBox>
        <VBox spacing="5.0">
            <children>
                <Label styleClass="header" text="Plural unit name"/>
                <TextField fx:id="pluralUnitField" minHeight="35.0" promptText="grams" styleClass="large">
                    <font>
                        <Font size="16.0"/>
                    </font>
                </TextField>
            </children>
            <padding>
                <Insets bottom="10.0" top="10.0"/>
            </padding>
        </VBox>
        <VBox spacing="5.0">
            <children>
                <Label styleClass="header" text="Smallest unit"/>
                <TextField fx:id="smallestUnitField" minHeight="35.0" promptText="0.5" styleClass="large">
                    <font>
                        <Font size="16.0"/>
                    </font>
                </TextField>
            </children>
            <padding>
                <Insets bottom="10.0" top="10.0"/>
            </padding>
        </VBox>
        <VBox spacing="5.0">
            <children>
                <Label styleClass="header" text="Lasts for (days)"/>
                <Spinner fx:id="useDurationSpinner" editable="true" maxHeight="1.7976931348623157E308"
                         maxWidth="1.7976931348623157E308" VBox.vgrow="SOMETIMES"/>
            </children>
            <padding>
                <Insets bottom="10.0" top="10.0"/>
            </padding>
        </VBox>
    </children>
    <stylesheets>
        <URL value="@../../stylesheets/core-ui.css"/>
        <URL value="@../../stylesheets/main.css"/>
    </stylesheets>
</VBox>
