<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import java.lang.*?>
<?import java.net.URL?>
<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity"
      prefHeight="570.0" prefWidth="833.0" spacing="10.0" xmlns="http://javafx.com/javafx/25"
      xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
    </padding>
    <children>
        <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" VBox.vgrow="SOMETIMES">
            <children>
                <Label fx:id="dishNameLabel" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                       styleClass="title" text="Dish name"/>
            </children>
            <VBox.margin>
                <Insets/>
            </VBox.margin>
        </VBox>
        <HBox prefHeight="100.0" prefWidth="200.0" spacing="20.0">
            <children>
                <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minWidth="150.0"
                      styleClass="rounded-container" HBox.hgrow="ALWAYS">
                    <children>
                        <Label alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                               text="Dish total" VBox.vgrow="ALWAYS">
                            <styleClass>
                                <String fx:value="large-label"/>
                                <String fx:value="flair-generic"/>
                            </styleClass>
                        </Label>
                        <Label fx:id="dishTotalLabel" alignment="CENTER" maxHeight="1.7976931348623157E308"
                               maxWidth="1.7976931348623157E308" text="0.00€" VBox.vgrow="ALWAYS">
                            <styleClass>
                                <String fx:value="xl-label"/>
                                <String fx:value="bold"/>
                            </styleClass>
                        </Label>
                    </children>
                    <HBox.margin>
                        <Insets/>
                    </HBox.margin>
                </VBox>
                <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minWidth="150.0"
                      styleClass="rounded-container" HBox.hgrow="ALWAYS">
                    <children>
                        <Label alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                               text="Cart total" VBox.vgrow="ALWAYS">
                            <styleClass>
                                <String fx:value="large-label"/>
                                <String fx:value="flair-generic"/>
                            </styleClass>
                        </Label>
                        <Label fx:id="dishProductsTotalLabel" alignment="CENTER" maxHeight="1.7976931348623157E308"
                               maxWidth="1.7976931348623157E308" text="0.00€" VBox.vgrow="ALWAYS">
                            <styleClass>
                                <String fx:value="xl-label"/>
                                <String fx:value="bold"/>
                            </styleClass>
                        </Label>
                    </children>
                </VBox>
                <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minWidth="150.0"
                      styleClass="rounded-container" HBox.hgrow="ALWAYS">
                    <children>
                        <Label alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                               text="Servings" VBox.vgrow="ALWAYS">
                            <styleClass>
                                <String fx:value="large-label"/>
                                <String fx:value="flair-generic"/>
                            </styleClass>
                        </Label>
                        <Label fx:id="servingCountLabel" alignment="CENTER" maxHeight="1.7976931348623157E308"
                               maxWidth="1.7976931348623157E308" text="4" VBox.vgrow="ALWAYS">
                            <styleClass>
                                <String fx:value="xl-label"/>
                                <String fx:value="bold"/>
                            </styleClass>
                        </Label>
                    </children>
                </VBox>
                <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minWidth="250.0"
                      styleClass="rounded-container" HBox.hgrow="ALWAYS">
                    <children>
                        <Label alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                               text="Price per serving" VBox.vgrow="ALWAYS">
                            <styleClass>
                                <String fx:value="large-label"/>
                                <String fx:value="flair-generic"/>
                            </styleClass>
                        </Label>
                        <Label fx:id="servingPriceLabel" alignment="CENTER" maxHeight="1.7976931348623157E308"
                               maxWidth="1.7976931348623157E308" text="0.00€" VBox.vgrow="ALWAYS">
                            <styleClass>
                                <String fx:value="xl-label"/>
                                <String fx:value="bold"/>
                            </styleClass>
                        </Label>
                    </children>
                </VBox>
            </children>
        </HBox>
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <VBox.margin>
                <Insets top="25.0"/>
            </VBox.margin>
            <children>
                <Label maxWidth="1.7976931348623157E308" text="Ingredients" HBox.hgrow="ALWAYS">
                    <styleClass>
                        <String fx:value="large-label"/>
                        <String fx:value="bold"/>
                    </styleClass>
                </Label>
                <Button fx:id="generateShoppingListButton" mnemonicParsing="false" text="Generate shopping list...">
                    <graphic>
                        <FontIcon iconLiteral="fltfmz-task-list-24" iconSize="16"/>
                    </graphic>
                </Button>
                <Button fx:id="generateRecipeSummaryButton" mnemonicParsing="false" text="Generate recipe summary">
                    <graphic>
                        <FontIcon iconLiteral="fltrmz-text-bullet-list-24" iconSize="16"/>
                    </graphic>
                </Button>
            </children>
        </HBox>
        <ListView fx:id="ingredientList" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                  styleClass="ingredient-list" VBox.vgrow="SOMETIMES"/>
    </children>
    <stylesheets>
        <URL value="@../../stylesheets/core-ui.css"/>
        <URL value="@../../stylesheets/main.css"/>
    </stylesheets>
</VBox>
