<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="525.0" prefWidth="403.0" spacing="10.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <Label styleClass="title" text="Transaction information">
         <VBox.margin>
            <Insets />
         </VBox.margin>
      </Label>
      <VBox spacing="5.0">
         <children>
            <Label fx:id="typeLabel" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minWidth="-Infinity" styleClass="flair-deposit" text="Deposit">
               <graphic>
                  <FontIcon fx:id="typeIcon" iconLiteral="fltral-add-circle-24" iconSize="16" wrappingWidth="20.0" />
               </graphic>
            </Label>
            <HBox spacing="5.0">
               <children>
                  <Label fx:id="dateLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="flair-generic" text="22/12/2026" HBox.hgrow="ALWAYS">
                     <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </padding>
                     <graphic>
                        <FontIcon iconLiteral="fltfal-calendar-20" iconSize="20" tabSize="0" textAlignment="CENTER" wrappingWidth="20.0" />
                     </graphic>
                  </Label>
                  <Label fx:id="timeLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="flair-generic" text="15:00:00" HBox.hgrow="ALWAYS">
                     <padding>
                        <Insets bottom="5.0" left="5.0" right="5.0" top="5.0" />
                     </padding>
                     <graphic>
                        <FontIcon iconLiteral="fltfal-clock-20" iconSize="20" tabSize="0" textAlignment="CENTER" wrappingWidth="20.0" />
                     </graphic>
                  </Label>
               </children>
            </HBox>
         </children>
      </VBox>
      <VBox spacing="5.0">
         <children>
            <Label fx:id="accountLabel" alignment="CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minWidth="-Infinity" styleClass="flair-account" text="Account A" />
            <HBox fx:id="transferPanel" alignment="CENTER" maxWidth="1.7976931348623157E308" spacing="5.0">
               <children>
                  <Label fx:id="transferFromLabel" maxHeight="1.7976931348623157E308" maxWidth="175.0" styleClass="flair-account" text="Account A" HBox.hgrow="ALWAYS" />
                  <FontIcon iconLiteral="fltfal-arrow-right-20" iconSize="20" HBox.hgrow="ALWAYS" />
                  <Label fx:id="transferToLabel" alignment="CENTER_RIGHT" maxHeight="1.7976931348623157E308" maxWidth="175.0" styleClass="flair-account" text="Account B" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
            <Label fx:id="amountLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="flair-generic" text="50.00">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
               <graphic>
                  <FontIcon iconLiteral="fltfmz-money-20" iconSize="20" />
               </graphic>
            </Label>
         </children>
         <VBox.margin>
            <Insets top="15.0" />
         </VBox.margin>
      </VBox>
      <VBox spacing="5.0" VBox.vgrow="ALWAYS">
         <children>
            <Label fx:id="categoryLabel" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="flair-generic" text="Food">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
               <graphic>
                  <FontIcon iconLiteral="fltfmz-star-20" iconSize="20" />
               </graphic>
            </Label>
            <VBox spacing="5.0" styleClass="flair-generic" VBox.vgrow="ALWAYS">
               <children>
                  <Label text="Comment">
                     <styleClass>
                        <String fx:value="normal-label" />
                        <String fx:value="bold" />
                     </styleClass>
                  </Label>
                  <Label fx:id="commentLabel" alignment="TOP_LEFT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" text="..." textAlignment="JUSTIFY" wrapText="true" VBox.vgrow="SOMETIMES">
                     <styleClass>
                        <String fx:value="normal-label" />
                        <String fx:value="bold" />
                     </styleClass>
                  </Label>
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
         </children>
         <VBox.margin>
            <Insets top="15.0" />
         </VBox.margin>
      </VBox>
   </children>
   <stylesheets>
      <URL value="@../../stylesheets/core-ui.css" />
      <URL value="@../../stylesheets/main.css" />
   </stylesheets>
</VBox>
