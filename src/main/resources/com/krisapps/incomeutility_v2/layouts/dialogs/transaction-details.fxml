<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import org.kordamp.ikonli.javafx.*?>
<?import java.lang.*?>
<?import java.net.URL?>
<VBox maxHeight="1.7976931348623157E308" maxWidth="440.0" minHeight="460.0" minWidth="440.0" spacing="10.0"
      xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   <children>
      <HBox maxWidth="1.7976931348623157E308" minHeight="50.0" spacing="10.0">
         <children>
             <Label fx:id="amountLabel" alignment="CENTER" maxHeight="1.7976931348623157E308" minWidth="140.0"
                    styleClass="flair-amount" text="50.00" HBox.hgrow="ALWAYS">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
                 <font>
                     <Font size="26.0"/>
                 </font>
            </Label>
             <VBox maxWidth="1.7976931348623157E308" spacing="5.0" HBox.hgrow="ALWAYS">
                 <children>
                     <Label fx:id="accountLabel" alignment="CENTER" maxHeight="1.7976931348623157E308"
                            maxWidth="1.7976931348623157E308" styleClass="flair-account" text="Account A"
                            VBox.vgrow="ALWAYS">
                         <graphic>
                             <FontIcon iconLiteral="fltral-building-bank-24" iconSize="12"/>
                         </graphic>
                     </Label>
                     <ScrollPane fx:id="transferPanel" fitToHeight="true" fitToWidth="true" VBox.vgrow="ALWAYS">
                         <content>
                             <HBox alignment="CENTER" maxHeight="1.7976931348623157E308"
                                   maxWidth="1.7976931348623157E308" spacing="5.0">
                                 <children>
                                     <Label fx:id="transferFromLabel" alignment="CENTER"
                                            maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                            styleClass="flair-account" text="Account A" HBox.hgrow="ALWAYS">
                                         <graphic>
                                             <FontIcon iconLiteral="fltral-building-bank-24" iconSize="12"/>
                                         </graphic>
                                     </Label>
                                     <FontIcon iconLiteral="fltfal-arrow-right-20" iconSize="20" HBox.hgrow="ALWAYS"/>
                                     <Label fx:id="transferToLabel" alignment="CENTER"
                                            maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308"
                                            styleClass="flair-account" text="Account B" HBox.hgrow="ALWAYS">
                                         <graphic>
                                             <FontIcon iconLiteral="fltral-building-bank-24" iconSize="12"/>
                                         </graphic>
                                     </Label>
                                 </children>
                             </HBox>
                         </content>
                     </ScrollPane>
                 </children>
             </VBox>
         </children>
      </HBox>
       <HBox spacing="10.0">
           <children>
               <Label fx:id="typeLabel" alignment="CENTER" maxHeight="1.7976931348623157E308" minWidth="140.0"
                      styleClass="flair-deposit" text="Deposit" HBox.hgrow="ALWAYS">
                   <graphic>
                       <FontIcon fx:id="typeIcon" iconLiteral="fltral-add-circle-24" iconSize="16"
                                 wrappingWidth="20.0"/>
                   </graphic>
               </Label>
               <Label fx:id="categoryLabel" alignment="CENTER" maxWidth="1.7976931348623157E308"
                      styleClass="flair-generic" text="Food" HBox.hgrow="ALWAYS">
                   <padding>
                       <Insets bottom="10.0" left="10.0" right="10.0" top="10.0"/>
                   </padding>
                   <graphic>
                       <FontIcon iconLiteral="fltfmz-star-20" iconSize="20"/>
                   </graphic>
               </Label>
           </children>
       </HBox>
       <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="5.0" VBox.vgrow="ALWAYS">
           <children>
               <HBox spacing="5.0">
                   <children>
                       <Label fx:id="datetimeLabel" alignment="CENTER" maxWidth="1.7976931348623157E308"
                              styleClass="flair-generic" text="dd/MM/yyyy, at HH:mm:ss" HBox.hgrow="ALWAYS">
                           <padding>
                               <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                           </padding>
                           <graphic>
                               <FontIcon iconLiteral="fltfal-clock-20" iconSize="20" tabSize="0" textAlignment="CENTER"
                                         wrappingWidth="20.0"/>
                           </graphic>
                       </Label>
                   </children>
               </HBox>
               <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="5.0"
                     styleClass="flair-generic" VBox.vgrow="ALWAYS">
               <children>
                  <Label text="Comment">
                     <styleClass>
                        <String fx:value="normal-label" />
                        <String fx:value="bold" />
                     </styleClass>
                  </Label>
                  <Label fx:id="commentLabel" alignment="TOP_LEFT" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" styleClass="normal-label" text="..." textAlignment="JUSTIFY" wrapText="true" VBox.vgrow="SOMETIMES" />
               </children>
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
         </children>
         <VBox.margin>
             <Insets top="20.0"/>
         </VBox.margin>
      </VBox>
       <TitledPane expanded="false" text="More info">
           <content>
               <ScrollPane fitToHeight="true" fitToWidth="true" maxHeight="1.7976931348623157E308"
                           maxWidth="1.7976931348623157E308">
                   <content>
                       <VBox maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" spacing="5.0">
                           <children>
                               <Label maxWidth="1.7976931348623157E308" text="Identifiers">
                                   <styleClass>
                                       <String fx:value="large-label"/>
                                       <String fx:value="bold"/>
                                   </styleClass>
                               </Label>
                               <Label fx:id="idLabel" maxWidth="1.7976931348623157E308" styleClass="flair-generic"
                                      text="Local ID: [id]">
                                   <padding>
                                       <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                                   </padding>
                                   <graphic>
                                       <FontIcon iconLiteral="fltral-archive-24" iconSize="20" tabSize="0"
                                                 textAlignment="CENTER" wrappingWidth="20.0"/>
                                   </graphic>
                               </Label>
                               <Label fx:id="cashewIdLabel" maxWidth="1.7976931348623157E308" styleClass="flair-generic"
                                      text="Cashew ID: [id]">
                                   <padding>
                                       <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                                   </padding>
                                   <graphic>
                                       <FontIcon iconLiteral="fltfal-app-generic-24" iconSize="20" tabSize="0"
                                                 textAlignment="CENTER" wrappingWidth="20.0"/>
                                   </graphic>
                               </Label>
                               <VBox fx:id="pairedInfoBox" spacing="5.0">
                                   <children>
                                       <Label maxWidth="1.7976931348623157E308" text="Paired with">
                                           <styleClass>
                                               <String fx:value="large-label"/>
                                               <String fx:value="bold"/>
                                           </styleClass>
                                       </Label>
                                       <Label fx:id="pairedIdLabel" maxWidth="1.7976931348623157E308"
                                              styleClass="flair-generic" text="Paired Cashew ID">
                                           <padding>
                                               <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                                           </padding>
                                           <graphic>
                                               <FontIcon iconLiteral="fltfal-app-generic-24" iconSize="20" tabSize="0"
                                                         textAlignment="CENTER" wrappingWidth="20.0"/>
                                           </graphic>
                                       </Label>
                                   </children>
                                   <VBox.margin>
                                       <Insets top="5.0"/>
                                   </VBox.margin>
                               </VBox>
                           </children>
                       </VBox>
                   </content>
                   <padding>
                       <Insets bottom="5.0" left="5.0" right="5.0" top="5.0"/>
                   </padding>
               </ScrollPane>
           </content>
       </TitledPane>
      <HBox maxWidth="1.7976931348623157E308" spacing="10.0">
         <VBox.margin>
            <Insets top="10.0" />
         </VBox.margin>
         <children>
            <Button fx:id="editButton" alignment="BASELINE_CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" text="Edit" textAlignment="CENTER" HBox.hgrow="SOMETIMES">
               <graphic>
                  <FontIcon iconLiteral="fltfal-edit-20" iconSize="12" textAlignment="CENTER" wrappingWidth="12.0" />
               </graphic>
            </Button>
            <Button fx:id="deleteButton" alignment="BASELINE_CENTER" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" mnemonicParsing="false" styleClass="destructive" text="Delete" textAlignment="CENTER">
               <graphic>
                  <FontIcon iconLiteral="fltfal-delete-20" iconSize="12" textAlignment="CENTER" wrappingWidth="12.0" />
               </graphic>
            </Button>
         </children>
      </HBox>
   </children>
   <stylesheets>
      <URL value="@../../stylesheets/core-ui.css" />
      <URL value="@../../stylesheets/main.css" />
   </stylesheets>
</VBox>
