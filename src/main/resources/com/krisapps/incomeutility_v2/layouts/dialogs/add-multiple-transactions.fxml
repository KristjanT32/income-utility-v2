                  <FontIcon iconLiteral="fltrmz-table-add-24" iconSize="12" tabSize="12" wrappingWidth="12.0" />
               </graphic>
            </Button>
         </children>
      </HBox>
      <ListView fx:id="transactionView" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" VBox.vgrow="ALWAYS" />
   </children>
